{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "jsx": "preserve",
    "types": [
      "vitest/globals",
      "node"
    ],
    "paths": {
      "@gcs-ssc/extensions": [
        "../../packages/gcs-ssc-extensions/src/index.ts"
      ],
      "@gcs-ssc/extensions/server": [
        "../../packages/gcs-ssc-extensions/src/server.ts"
      ],
      "@gcs-ssc/extensions/nuxt": [
        "../../packages/gcs-ssc-extensions/src/nuxt.ts"
      ]
    },
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "skipLibCheck": true
  },
  "include": [
    "components/**/*.ts",
    "components/**/*.vue",
    "server/**/*.ts",
    "tests/**/*.ts",
    "types/**/*.d.ts",
    "extension.config.ts"
  ]
}
