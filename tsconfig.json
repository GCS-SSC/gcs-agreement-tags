{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "jsx": "preserve",
    "types": [
      "vitest/globals",
      "node"
    ],
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "skipLibCheck": true
  },
  "include": [
    "components/**/*.ts",
    "components/**/*.vue",
    "server/**/*.ts",
    "tests/**/*.ts",
    "types/**/*.d.ts",
    "extension.config.ts"
  ]
}
